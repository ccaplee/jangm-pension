		<style id="wp-custom-css">
			/* 헤더 */

.site-header,
#mobile-header {
    box-shadow: 0px 1px 5px rgba(0, 0, 0, 0.1);
}

@media (max-width: 768px) {
    .site-header .header-image {
        width: 180px;
    }
}

@media (max-width: 910px) and (min-width: 769px) {
    .site-logo,
    .site-branding {
        margin-bottom: 0;
    }
}


/* 푸터 */

.footer-nav {
    font-size: 15px;
    color: #ffffff;
    list-style: none;
    margin: 0px;
}

.footer-nav a {
    color: #ffffff;
}

.footer-nav li:not(:first-child):before {
    content: " ";
    padding: 0 9px 0 9px;
}

.footer-nav li {
    display: inline-block;
}

.footer-company {
    font-size: 13px;
    color: #dddddd;
    list-style: none;
    margin: 0px;
    padding: 0;
}

.footer-company li {
    display: inline;
}

.footer-company li:not(:first-child)::before {
    content: "|";
    padding: 0 7px;
}

.footer-company li:nth-child(4)::before {
    content: "\A";
    white-space: pre;
    padding: 0;
}

@media (max-width: 768px) {
    .footer-company {
        font-size: 11px;
    }
    .footer-company li:nth-child(2)::before,
    .footer-company li:nth-child(4)::before,
    .footer-company li:nth-child(7)::before {
        content: "\A";
        white-space: pre;
        padding: 0;
    }
}


/* SNS 공유 버튼 */

.sns-btn {
    margin-top: 5px;
}

.sns-btn ul {
    list-style-type: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
}

.sns-btn li {
    float: left;
    margin-right: 7px;
}

.sns-btn a {
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
}

.sns-icon {
    width: 30px;
    height: 30px;
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
}

.sns-kakao {
    background-image: url('https://www.telltrip.com/wp-content/uploads/2026/03/kakao_icon.png');
}

.sns-naver {
    background-image: url('https://www.telltrip.com/wp-content/uploads/2026/03/naver_icon.png');
}

.sns-facebook {
    background-image: url('https://www.telltrip.com/wp-content/uploads/2026/03/facebook_icon.png');
}

.sns-link {
    background-image: url('https://www.telltrip.com/wp-content/uploads/2026/03/copy_icon.png');
}


/* 댓글 */

.comment-respond form textarea {
    font-size: 15px;
    height: 45px;
    min-height: 45px !important;
}

.comment-box-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
}

.comment-box-wrapper textarea {
    flex: 1;
    resize: none;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
}

.comment-box-wrapper .submit-button {
    padding: 8px 18px;
    background-color: #0059b5;
    color: #fff;
    border-radius: 5px;
    cursor: pointer;
}

.comment-box-wrapper .submit-button:hover {
    background-color: #003469;
}

.comments-title {
    font-size: 23px;
    font-weight: 600;
}

.comment-content {
    padding: 0px;
    margin-top: 0px;
    border: 0px;
}

.comment-content p {
    margin-bottom: 0em;
}

.comment-body {
    padding: 5px 0 !important;
}

.comment-author-info {
    display: flex;
    align-items: center;
}

.comment-author,
.entry-meta {
    margin-right: 10px;
}

ol.comment-list {
    margin: 0;
}

.site-main .comment-navigation {
    margin: 10px 0 0 0;
}

#comment-nav-above {
    display: none;
}

.reply {
    display: none;
}


/* 싱글 포스트 본문 */

.single-post .entry-content h2 {
    font-size: 19px;
    color: #1b1b1b;
    margin-bottom: 18px;
    padding-left: 10px;
    border-left: 3px solid #1b1b1b;
}

.single-post .entry-content h3 strong {
    font-weight: 500;
}

.wp-block-image.size-large img {
    display: block;
    margin: 0 auto;
}

@media (max-width: 768px) {
    body.single .entry-content .wp-block-image {
        width: calc(100% + 20px);
        margin-left: -10px;
        margin-right: -10px;
        max-width: 100vw;
        box-sizing: border-box;
    }
}

.single-post .entry-content a[href^="https://www.telltrip.com"] {
    color: #0059b5;
    font-weight: 700;
}

.single-post .entry-content a:not([href^="https://www.telltrip.com"]) {
    text-decoration: underline;
}

.tags-links {
    font-size: 11px;
}


/* 목록 공통 */

ol, ul {
    margin: 0 0 1.5em 1.5em;
}


/* 페이지 목차 네비게이션 */

ul.wp-block-list.nav_pagelink {
    margin: 0 0 18px 0;
}

ul.nav_pagelink li {
    display: inline-block;
    border: 1px solid #c8c8c8;
    text-align: center;
    padding: 8px 7px;
    margin-bottom: 5px;
}

ul.nav_pagelink li a {
    font-size: 14px;
    font-weight: 700;
    color: #545454;
}

ul.nav_pagelink li.active {
    border: 1px solid #0059b5 !important;
}

ul.nav_pagelink li.active a,
body.policy .body ul.nav_pagelink li:hover a {
    color: #0059b5 !important;
}


/* 페이지 목차 */

.custom-page1 li {
    margin-top: 0.4rem;
}


/* 사이드바 제목 말줄임 */

.text-overflow-hidden {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}


/* 카테고리/아카이브 페이지 */

h1.wp-block-query-title {
    margin-bottom: 0;
}

.no-results.not-found h1 {
    font-size: 27px;
}


/* 광고 배너 */

.tripad {
    margin: 20px 0;
}		</style>
		<style>.perfmatters-lazy-youtube{position:relative;width:100%;max-width:100%;height:0;padding-bottom:56.23%;overflow:hidden}.perfmatters-lazy-youtube img{position:absolute;top:0;right:0;bottom:0;left:0;display:block;width:100%;max-width:100%;height:auto;margin:auto;border:none;cursor:pointer;transition:.5s all;-webkit-transition:.5s all;-moz-transition:.5s all}.perfmatters-lazy-youtube img:hover{-webkit-filter:brightness(75%)}.perfmatters-lazy-youtube .play{position:absolute;top:50%;left:50%;right:auto;width:68px;height:48px;margin-left:-34px;margin-top:-24px;background:url(https://www.telltrip.com/wp-content/plugins/perfmatters/img/youtube.svg) no-repeat;background-position:center;background-size:cover;pointer-events:none;filter:grayscale(1)}.perfmatters-lazy-youtube:hover .play{filter:grayscale(0)}.perfmatters-lazy-youtube iframe{position:absolute;top:0;left:0;width:100%;height:100%;z-index:99}.wp-has-aspect-ratio .wp-block-embed__wrapper{position:relative;}.wp-has-aspect-ratio .perfmatters-lazy-youtube{position:absolute;top:0;right:0;bottom:0;left:0;width:100%;height:100%;padding-bottom:0}</style></head>

